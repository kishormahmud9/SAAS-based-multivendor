// =============================================================================
// TICKET — Customer support tickets with reply thread
// =============================================================================
model Ticket {
  id         String         @id @default(cuid())
  userId     String
  subject    String
  category   TicketCategory @default(OTHER)
  priority   TicketPriority @default(MEDIUM)
  status     TicketStatus   @default(OPEN)
  assignedTo String?        // admin userId
  orderId    String?        // linked order if applicable
  closedAt   DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user       User           @relation(fields: [userId], references: [id])
  messages   TicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@map("tickets")
}

model TicketMessage {
  id          String   @id @default(cuid())
  ticketId    String
  senderId    String   // userId of sender
  message     String
  attachments String[]
  isInternal  Boolean  @default(false) // internal staff note
  createdAt   DateTime @default(now())

  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_messages")
}