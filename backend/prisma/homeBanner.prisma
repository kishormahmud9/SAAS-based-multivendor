// =============================================================================
// HOME BANNER — Main homepage sliders/banners
// =============================================================================
model HomeBanner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  image     String
  link      String?
  backgroundType String @default("IMAGE")
  targetDate DateTime?
  type      BannerType @default(HERO)
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("home_banners")
}
