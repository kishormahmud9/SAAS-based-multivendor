<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ReadyMart Verification Code</title>
  </head>
  <body style="margin:0;padding:0;background-color:#f4f7fb;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f7fb;padding:40px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="width:100%;max-width:600px;background-color:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 10px 25px rgba(0,0,0,0.05);border:1px solid #eaedf3;">
            
            <!-- Header -->
            <tr>
              <td align="center" style="padding:32px 24px;border-bottom:1px solid #eaedf3;background:linear-gradient(135deg, #ff6b2b 0%, #e33a24 100%);">
                <div style="font-size:28px;font-weight:800;letter-spacing:-0.5px;color:#ffffff;">
                  Ready<span style="color:#1e3a8a;">Mart</span>
                </div>
              </td>
            </tr>

            <!-- Content Area -->
            <tr>
              <td style="padding:48px 40px;">
                <div style="font-size:24px;font-weight:700;color:#111827;margin-bottom:16px;text-align:center;">
                  Your Verification Code
                </div>
                <div style="font-size:16px;line-height:1.6;color:#4b5563;margin-bottom:32px;text-align:center;">
                  Hi <strong style="color:#111827;"><%= name %></strong>,<br/>
                  We received a request to verify your account. Please use the one-time password (OTP) below.
                </div>

                <!-- OTP Box -->
                <div style="text-align:center;margin-bottom:28px;">
                  <div style="display:inline-block;padding:20px 48px;border:2px dashed #cbd5e1;border-radius:12px;background-color:#f8fafc;font-size:40px;font-weight:800;letter-spacing:12px;color:#1e3a8a;box-shadow:inset 0 2px 4px rgba(0,0,0,0.02);">
                    <%= otp %>
                  </div>
                </div>

                <!-- Expiry Badge -->
                <div style="text-align:center;margin-bottom:40px;">
                  <span style="display:inline-block;padding:8px 20px;background-color:#eff6ff;color:#1d4ed8;font-size:14px;font-weight:600;border-radius:24px;">
                    <span style="display:inline-block;margin-right:6px;">⏱</span> Valid for 5 minutes
                  </span>
                </div>

                <!-- Warning Box -->
                <div style="background-color:#fef2f2;border:1px solid #fecaca;padding:20px;font-size:14px;line-height:1.6;color:#991b1b;border-radius:12px;text-align:center;">
                  <strong style="color:#b91c1c;display:block;margin-bottom:4px;">Security Alert</strong>
                  ReadyMart will never ask you to share this code. If you didn't request this verification, please ignore this email to keep your account safe.
                </div>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td align="center" style="padding:32px 24px;background-color:#f8fafc;font-size:13px;color:#64748b;line-height:1.6;">
                © <%= new Date().getFullYear() %> ReadyMart. All rights reserved.<br/>
                Delivering premium shopping experiences.
              </td>
            </tr>
            
          </table>
          
          <div style="margin-top:24px;text-align:center;font-size:12px;color:#94a3b8;">
            This is an automated message, please do not reply.
          </div>
        </td>
      </tr>
    </table>
  </body>
</html>
